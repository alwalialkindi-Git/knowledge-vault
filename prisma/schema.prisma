generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Enums ----------

enum ResourceType {
  book
  video
  course
  article
  note
}

enum ResourceStatus {
  not_started
  in_progress
  completed
  on_hold
}

enum UnitLabel {
  pages
  lessons
  videos
  minutes
  chapters
}

enum Priority {
  low
  normal
  high
}

enum NoteType {
  note
  takeaway
  quote
  action_item
}

enum ContentSource {
  manual
  ai
}

enum CardStatus {
  active
  suspended
}

// ---------- Models ----------

// Legacy shared lookup table — kept for DB compatibility.
// Active code uses learning_domains (per-user) instead.
model FocusArea {
  id        String     @id @default(uuid()) @db.Uuid
  key       String     @unique
  nameEn    String     @map("name_en")
  nameAr    String     @map("name_ar")
  color     String
  sortOrder Int        @map("sort_order")

  @@map("focus_areas")
}

// Per-user domain tags, replacing focus_areas.
// Created by supabase/migrations/001_learning_domains.sql
model LearningDomain {
  id         String     @id @default(uuid()) @db.Uuid
  userId     String     @map("user_id") @db.Uuid
  name       String
  icon       String?
  color      String?
  sortOrder  Int        @default(0) @map("sort_order")
  isArchived Boolean    @default(false) @map("is_archived")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @default(now()) @updatedAt @map("updated_at")
  resources  Resource[]

  @@index([userId, sortOrder])
  @@map("learning_domains")
}

model Resource {
  id                String          @id @default(uuid()) @db.Uuid
  userId            String          @map("user_id") @db.Uuid
  title             String
  type              ResourceType
  focusAreaId       String?         @map("focus_area_id") @db.Uuid  // legacy column — kept for DB compat
  learningDomainId  String?         @map("learning_domain_id") @db.Uuid
  learningDomain    LearningDomain? @relation(fields: [learningDomainId], references: [id], onDelete: SetNull)
  status            ResourceStatus  @default(not_started)
  sourceUrl         String?         @map("source_url")
  authorOrCreator   String?         @map("author_or_creator")
  totalUnits        Int?            @map("total_units")
  completedUnits    Int             @default(0) @map("completed_units")
  unitLabel         UnitLabel?      @map("unit_label")
  priority          Priority        @default(normal)
  rating            Int?
  coverImageUrl     String?         @map("cover_image_url")
  fileKey           String?         @map("file_key")
  fileName          String?         @map("file_name")
  fileSize          Int?            @map("file_size")
  mimeType          String?         @map("mime_type")
  aiSummary         String?         @map("ai_summary")
  createdAt         DateTime        @default(now()) @map("created_at")
  startedAt         DateTime?       @map("started_at")
  completedAt       DateTime?       @map("completed_at")
  updatedAt         DateTime        @default(now()) @updatedAt @map("updated_at")
  notes             Note[]
  items             ResourceItem[]
  conceptLinks      ConceptLink[]

  @@index([userId])
  @@index([learningDomainId])
  @@map("resources")
}

model ResourceItem {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  resourceId       String    @map("resource_id") @db.Uuid
  resource         Resource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  title            String
  description      String?
  itemType         String    @map("item_type") // chapter | lesson | video | article — text for flexibility
  url              String?
  estimatedMinutes Int?      @map("estimated_minutes")
  orderIndex       Int       @default(0) @map("order_index")
  isCompleted      Boolean   @default(false) @map("is_completed")
  completedAt      DateTime? @map("completed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")

  conceptLinks     ConceptLink[]

  @@index([userId])
  @@index([resourceId])
  @@index([resourceId, orderIndex])
  @@map("resource_items")
}

model Note {
  id           String         @id @default(uuid()) @db.Uuid
  userId       String         @map("user_id") @db.Uuid
  resourceId   String         @map("resource_id") @db.Uuid
  resource     Resource       @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  type         NoteType       @default(note)
  content      String
  location     String?
  isReviewCard Boolean        @default(false) @map("is_review_card")
  isCompleted  Boolean        @default(false) @map("is_completed")
  completedAt  DateTime?      @map("completed_at")
  source       ContentSource  @default(manual)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @default(now()) @updatedAt @map("updated_at")
  reviewCard   ReviewCard?
  conceptLinks ConceptLink[]

  @@index([userId])
  @@index([resourceId])
  @@map("notes")
}

// Knowledge graph node belonging to a single user.
// Never nested inside a domain, resource, or any other entity.
// Created by supabase/migrations/003_concepts.sql
model Concept {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @map("user_id") @db.Uuid
  name         String
  description  String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @default(now()) @updatedAt @map("updated_at")
  links        ConceptLink[]

  @@unique([userId, name])
  @@index([userId])
  @@map("concepts")
}

// Polymorphic link: exactly one of noteId / resourceId / resourceItemId is non-null.
// The DB CHECK constraint enforces this; CASCADE deletes keep rows clean.
model ConceptLink {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  conceptId      String       @map("concept_id") @db.Uuid
  concept        Concept      @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  noteId         String?      @unique @map("note_id") @db.Uuid
  note           Note?        @relation(fields: [noteId], references: [id], onDelete: Cascade)
  resourceId     String?      @unique @map("resource_id") @db.Uuid
  resource       Resource?    @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  resourceItemId String?      @unique @map("resource_item_id") @db.Uuid
  resourceItem   ResourceItem? @relation(fields: [resourceItemId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([conceptId])
  @@index([userId])
  @@map("concept_links")
}

model ReviewCard {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  noteId         String        @unique @map("note_id") @db.Uuid
  note           Note          @relation(fields: [noteId], references: [id], onDelete: Cascade)
  intervalDays   Int           @default(1) @map("interval_days")
  nextReviewAt   DateTime      @map("next_review_at") @db.Date
  lastReviewedAt DateTime?     @map("last_reviewed_at")
  reviewCount    Int           @default(0) @map("review_count")
  status         CardStatus    @default(active)
  source         ContentSource @default(manual)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at")

  @@index([userId])
  @@map("review_cards")
}
